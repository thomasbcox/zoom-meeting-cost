# Dev: the API server's port (Vite proxies /ws and /api here). The dev script
# sets this to 8787; it is kept separate from PORT so dev launchers that inject
# a generic PORT (e.g. the preview panel) can't steer the API onto the web port.
API_PORT=8787

# Prod: when Express serves the built client on a single port, the platform's
# conventional PORT is used (API_PORT falls back to PORT, then 8787).
# PORT=8787

# --- Zoom App credentials (only needed for real in-Zoom testing) ------------
# Create an app at https://marketplace.zoom.us (type: "Zoom Apps"), then copy
# its credentials here. Leave blank to run the local prototype with mock data.
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# Must exactly match the OAuth Redirect URL registered in the Marketplace,
# e.g. https://<your-ngrok-subdomain>.ngrok.app/auth/callback
ZOOM_REDIRECT_URI=
