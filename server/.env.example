# This file is OPTIONAL. The server boots fine without a .env (scripts use
# `node --env-file-if-exists=.env`); on a platform like Railway, set these as
# injected environment variables instead. Copy to `.env` for local dev.

# Dev: the API server's port (Vite proxies /api here). The dev script sets this
# to 8787; it is kept separate from PORT so dev launchers that inject a generic
# PORT (e.g. the preview panel) can't steer the API onto the web port.
API_PORT=8787

# Prod: when Express serves the built client on a single port, the platform's
# conventional PORT is used (API_PORT falls back to PORT, then 8787). On Railway
# PORT is injected automatically — do NOT set it yourself.
# PORT=8787

# --- Zoom App credentials (only needed for real in-Zoom testing) ------------
# Create an app at https://marketplace.zoom.us (type: "Zoom Apps"), then copy
# its credentials here. Leave blank to run the local prototype with mock data.
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# Must exactly match the OAuth Redirect URL registered in the Marketplace,
# e.g. https://<app>.up.railway.app/auth/callback (Railway) or an ngrok URL.
ZOOM_REDIRECT_URI=

# NOTE: VITE_USE_ZOOM is a CLIENT BUILD-TIME var (Vite inlines it into the
# bundle), not a server runtime var — it lives in client/.env.local locally, and
# must be set to 1 in Railway's build environment. See README "Deploy to Railway".
